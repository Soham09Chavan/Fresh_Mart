<style>
:root{
    --primary:#ff6b00;
    --secondary:#2ecc71;
    --dark:#0b0b0b;
    --glass:rgba(255,255,255,0.06);
}

*{box-sizing:border-box;}

body{
    margin:0;
    font-family:'Poppins',sans-serif;
    background:var(--dark);
    color:white;
}

/* HEADER */
header{
    position:fixed;
    top:0;
    width:100%;
    padding:15px 6%;
    display:flex;
    justify-content:space-between;
    align-items:center;
    backdrop-filter:blur(20px);
    background:rgba(0,0,0,0.7);
    z-index:100;
}

.logo{
    font-size:26px;
    font-weight:700;
}
.logo span{color:var(--primary);}

.search-box{
    width:260px;
    padding:10px 20px;
    border-radius:30px;
    border:none;
    outline:none;
}

/* HERO */
.hero{
    padding:150px 20px 70px;
    text-align:center;
}

.hero h1{
    font-size:3.2rem;
    color:var(--primary);
}

.hero p{
    color:#ccc;
    font-size:1.2rem;
}

/* MAIN */
main{
    padding:40px 8%;
}

.products{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(250px,1fr));
    gap:35px;
}

.card{
    background:var(--glass);
    border-radius:20px;
    padding:20px;
    text-align:center;
    transition:0.3s;
    border:1px solid rgba(255,255,255,0.1);
}

.card:hover{
    transform:translateY(-10px) scale(1.05);
    box-shadow:0 20px 40px rgba(255,107,0,0.3);
}

.card img{
    height:180px;
    max-width:100%;
    object-fit:contain;
    margin-bottom:10px;
}

.price{
    font-size:1.3rem;
    color:var(--secondary);
    font-weight:600;
}

button{
    margin-top:10px;
    padding:10px 22px;
    border:none;
    border-radius:12px;
    background:var(--primary);
    color:white;
    font-weight:600;
    cursor:pointer;
}

button:hover{
    background:var(--secondary);
}

/* FOOTER */
footer{
    margin-top:60px;
    padding:40px 8%;
    background:#111;
    color:#aaa;
}
</style>
</head>

